package collection_and_stream;

public class Employee {
	private int employeeId;
	private String name;
	private String deparmtent;
	private String designation;
	private double salary;
	private int yearsOfExperience;
	
	
	public Employee(int employeeId, String name, String deparmtent, String designation, double salary,
			int yearsOfExperience) {
		super();
		this.employeeId = employeeId;
		this.name = name;
		this.deparmtent = deparmtent;
		this.designation = designation;
		this.salary = salary;
		this.yearsOfExperience = yearsOfExperience;
	}
	public void setEmployeeId(int employeeId) {
		this.employeeId=employeeId;
	}
	public int getEmployeeId() {
		return employeeId;
	}
	public final String getName() {
		return name;
	}
	public final void setName(String name) {
		this.name = name;
	}
	public final String getDeparmtent() {
		return deparmtent;
	}
	public final void setDeparmtent(String deparmtent) {
		this.deparmtent = deparmtent;
	}
	public final String getDesignation() {
		return designation;
	}
	public final void setDesignation(String designation) {
		this.designation = designation;
	}
	public final double getSalary() {
		return salary;
	}
	public final void setSalary(double salary) {
		this.salary = salary;
	}
	public final int getYearsOfExperience() {
		return yearsOfExperience;
	}
	public final void setYearsOfExperience(int yearsOfExperience) {
		this.yearsOfExperience = yearsOfExperience;
	}
	
	
}
