package junitdemo;

public class Student {
	private int id;
	private String name;
	private int marks1;
	private int marks2;
	private int marks3;
	public Student(int id, String name, int marks1, int marks2, int marks3) {
		super();
		this.id = id;
		this.name = name;
		this.marks1 = marks1;
		this.marks2 = marks2;
		this.marks3 = marks3;
	}
	public final int getId() {
		return id;
	}
	public final void setId(int id) {
		this.id = id;
	}
	public final String getName() {
		return name;
	}
	public final void setName(String name) {
		this.name = name;
	}
	public final int getMarks1() {
		return marks1;
	}
	public final void setMarks1(int marks1) {
		this.marks1 = marks1;
	}
	public final int getMarks2() {
		return marks2;
	}
	public final void setMarks2(int marks2) {
		this.marks2 = marks2;
	}
	public final int getMarks3() {
		return marks3;
	}
	public final void setMarks3(int marks3) {
		this.marks3 = marks3;
	}
	
	
}
