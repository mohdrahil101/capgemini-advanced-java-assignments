package collection_and_stream;

import java.util.Objects;

public class Employee {
	private int employeeId;
	private String name;
	private String deparmtent;
	private String designation;
	private double salary;
	private int yearsOfExperience;
	
	public Employee(int employeeId, String name, String deparmtent, String designation, double salary,int yearsOfExperience) {
		super();
		this.employeeId = employeeId;
		this.name = name;
		this.deparmtent = deparmtent;
		this.designation = designation;
		this.salary = salary;
		this.yearsOfExperience = yearsOfExperience;
	}
	public void setEmployeeId(int employeeId) {
		this.employeeId=employeeId;
	}
	public int getEmployeeId() {
		return employeeId;
	}
	public String getName() {
		return name;
	}
	public void setName(String name) {
		this.name = name;
	}
	public String getDeparmtent() {
		return deparmtent;
	}
	public void setDepartment(String deparmtent) {
		this.deparmtent = deparmtent;
	}
	public String getDesignation() {
		return designation;
	}
	public void setDesignation(String designation) {
		this.designation = designation;
	}
	public double getSalary() {
		return salary;
	}
	public void setSalary(double salary) {
		this.salary = salary;
	}
	public int getYearsOfExperience() {
		return yearsOfExperience;
	}
	public void setYearsOfExperience(int yearsOfExperience) {
		this.yearsOfExperience = yearsOfExperience;
	}
	@Override
	public String toString() {
		return "Employee [employeeId=" + employeeId + ", name=" + name + ", deparmtent=" + deparmtent + ", designation="
				+ designation + ", salary=" + salary + ", yearsOfExperience=" + yearsOfExperience + "]";
	}
	@Override
	public int hashCode() {
		return Objects.hash(deparmtent, designation, employeeId, name, salary, yearsOfExperience);
	}
	@Override
	public boolean equals(Object obj) {
		if (this == obj)
			return true;
		if (obj == null)
			return false;
		if (getClass() != obj.getClass())
			return false;
		Employee other = (Employee) obj;
		return Objects.equals(deparmtent, other.deparmtent) && Objects.equals(designation, other.designation)
				&& employeeId == other.employeeId && Objects.equals(name, other.name)
				&& Double.doubleToLongBits(salary) == Double.doubleToLongBits(other.salary)
				&& yearsOfExperience == other.yearsOfExperience;
	}
	
	
	
}
