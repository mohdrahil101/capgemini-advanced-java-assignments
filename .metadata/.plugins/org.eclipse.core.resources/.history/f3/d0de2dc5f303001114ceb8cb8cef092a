import java.util.*;
import java.util.stream.Collectors;

/**
 * 
 */
public class EmployeeManagement {
	public static void execution() {
		List<Employee> employees = new ArrayList<>();
		employees.add(new Employee(101,"Raju","IT","SDE",30000.0,3));
		employees.add(new Employee(102,"Kaju","Hardware","D",90000.0,2));
		employees.add(new Employee(103,"Maju","Core","Manager",40000.0,5));
		employees.add(new Employee(104,"Naju","IT","Sales",100000.0,8));
		
		
		double averageSalary=employees.stream().mapToDouble(Employee::getSalary).average().orElse(0.0);
		System.out.println("Average Salary: "+averageSalary);
		
		Employee highestSalaryEmployee=employees.stream().max(Comparator.comparing(Employee::getSalary)).orElse(null);
		System.out.println("Highest Salary Employee: "+highestSalaryEmployee);
		
		List<Employee> salaryAbove=employees.stream().filter(e->e.getSalary()>80000).collect(Collectors.toList());
		System.out.println("Salary Above 80000:");
		for(int i=0;i<salaryAbove.size();i++) {
			System.out.println(salaryAbove.get(i).getName());
		}
		
		
		Map<String, Long> empCountByDept = employees.stream().collect(Collectors.groupingBy(Employee::getDeparmtent,Collectors.counting()));
        System.out.println("\nNumber of Employees in Each Department:");
        empCountByDept.forEach((dept, count) ->
                System.out.println(dept + " : " + count));

        
        List<Employee> itExperiencedEmployees = employees.stream().filter(e -> e.getDeparmtent().equalsIgnoreCase("IT"))
        												 .filter(e -> e.getYearsOfExperience() > 5)
        		                                         .collect(Collectors.toList());

        System.out.println("\nIT Employees with > 5 Years Experience:");
        itExperiencedEmployees.forEach(System.out::println);
	}
}
